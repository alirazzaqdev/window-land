# ─── Databases ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/windowland
DATABASE_URL=postgresql://<user>:<pass>@<host>.neon.tech/windowland?sslmode=require
REDIS_URL=redis://default:<pass>@<host>.upstash.io:6379

# ─── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email ───────────────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=info@windowland.ae
EMAIL_TO=info@windowland.ae
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey

# ─── WhatsApp Cloud API ──────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_TO=+971504552652

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
ADMIN_USERNAME=waqas
ADMIN_PASSWORD_HASH=

# ─── Python Microservice ─────────────────────────────────────
PYTHON_API_URL=https://python.railway.app

# ─── Next.js Public ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.windowland.ae
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=971504552652

# ─── Sentry ──────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Node env ────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
